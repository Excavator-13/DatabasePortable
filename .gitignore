# === Python 环境与缓存 ===
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境目录 (根据你实际使用的命名调整，如 venv, env, .venv)
venv/
env/
.venv/
ENV/

# 打包与分发文件
*.egg
*.egg-info/
dist/
build/
eggs/
sdist/
wheels/
*.manifest
*.spec

# === 环境变量配置 (包含敏感信息，不应提交) ===
.env
.env.local
.env.*.local

# === 数据库与日志 ===
*.sqlite3
*.db
*.log
logs/

# === 编辑器 / IDE 配置 ===
.vscode/
.idea/
*.swp
*.swo
*~

# === 操作系统生成文件 ===
.DS_Store
Thumbs.db
desktop.ini

# === 其他 ===
*.bak
*.tmp
